msgstr "Rata-rata (geometrik)"

msgid "Mean (harmonic)"
msgstr "Rata-rata (harmonik)"

msgid "Coefficient of variation"
msgstr "Koefisien variasi"

msgid "MAD"
msgstr "MAD"

msgid "MAD robust"
msgstr "Kekuatan MAD"

msgid "IQR"
msgstr "IQR"

msgid "Skewness"
msgstr "Kecondongan"

