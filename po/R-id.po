msgid "Time Series Plot"
msgstr "Plot Deret Waktu"

msgid "Lag Plot"
msgstr "Plot Lag"

msgid ""
"The specified lag, %1$s, is too large given the %2$s observations in the "
"data. Please choose a smaller lag."
msgstr ""
"Lag yang ditentukan, %1$s, terlalu besar mengingat terdapat %2$s pengamatan "
"dalam data. Silakan pilih lag yang lebih kecil."

msgid "Autocorrelation Function"
msgstr "Fungsi Autokorelasi"

msgid "Partial Autocorrelation Function"
msgstr "Fungsi Autokorelasi Parsial"

msgid "Descriptive Statistics"
msgstr "Statistik Deskriptif"

msgid "Valid"
msgstr "Valid"

msgid "Missing"
msgstr "Hilang"

msgid "Mean"
msgstr "Rata-rata"

msgid "Std. Deviation"
msgstr "Std. Deviasi"

msgid "Variance"
msgstr "Varians"

msgid "Range"
msgstr "Rentang"

msgid "Minimum"
msgstr "Minimum"

