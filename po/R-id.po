msgstr "Plot Q-Q"

msgid "Plotting is not possible: Variable only contains NA!"
msgstr "Pembuatan plot tidak memungkinkan: Variabel hanya memuat NA!"

msgid "Pie charts"
msgstr "Diagram lingkaran"

msgid "Stem and Leaf"
msgstr "Batang dan Daun"

msgid "Scatter Plots"
msgstr "Plot Sebar"

