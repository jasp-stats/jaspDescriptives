msgstr "Plot Likert"

msgid ""
"Excluded %1$i rows from the analysis that correspond to the missing values "
"of the split-by variable %2$s"
msgstr ""
"Sebanyak %1$i baris dikecualikan dari analisis karena sesuai dengan nilai "
"yang hilang pada variabel pemisah %2$s"

msgid "%s%% Confidence Interval Mean"
msgstr "Rata-rata Interval Kepercayaan %s%%"

msgid "%s%% Confidence Interval Std. Dev."
msgstr "%s%% Std. Dev. Interval Kepercayaan"

msgid "%s%% Confidence Interval Variance"
msgstr "Varians Interval Kepercayaan %s%%"

