msgid "Start"
msgstr "開始"

msgctxt "DescriptivesTimeSeriesForm|"
msgid "End"
msgstr "結束"

msgctxt "DescriptivesTimeSeriesForm|"
msgid "Time index"
msgstr "時間指標"

msgctxt "DescriptivesTimeSeriesForm|"
msgid "Date"
msgstr "日期"

msgctxt "DescriptivesTimeSeriesForm|"
msgid "Plots"
msgstr "圖"

msgctxt "DescriptivesTimeSeriesForm|"
msgid "Time series plot"
msgstr "時間序列圖"

msgctxt "DescriptivesTimeSeriesForm|"
msgid "Plots the dependent variable (y-axis) over time (x-axis)."
msgstr "將依變項（Y 軸）對時間（X 軸）繪圖。"

